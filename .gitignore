# Claude Code 세션 설정
.claude/

# 가상환경
.venv/
.venv-ov/

# 파이썬 캐시
__pycache__/
*.pyc

# 변환된 OpenVINO 모델 (optimum-cli로 재생성 가능, 약 780MB)
models/

# 테스트 미디어·생성물 (테스트 스크립트 .py는 커밋 대상)
test_audio/*.mp3
test_audio/*.mp4
test_audio/*.mkv
test_audio/*.wav
test_audio/*.txt

# 벤치마크용 다운로드 데이터셋 (fetch_datasets.py로 재생성)
test_audio/datasets/

# 데이터셋 원본 보존 (FLEURS/ESC-50 parquet, 약 5GB — 로컬 전용)
datasets_raw/

# 학습된 고스트 어댑터 가중치 (재학습 가능)
train/*.pt

# 비밀 토큰
token.txt
